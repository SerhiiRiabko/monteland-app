# ══════════════════════════════════════════════════════
#  MonteLand — Environment Variables
#  Copy to .env and fill in real values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────
ENVIRONMENT=development          # development | production
DEBUG=true

# ── Security (generate with: openssl rand -hex 32) ──
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Admin panel credentials ──────────────────────────
ADMIN_EMAIL=admin@monteland.me
# IMPORTANT: store bcrypt HASH, not plain password!
# Generate: python3 -c "from passlib.hash import bcrypt; print(bcrypt.hash('YOUR_PASS'))"
ADMIN_PASSWORD=CHANGE_ME_bcrypt_hash_of_password

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_USER=monteland
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=monteland

# Async URL (FastAPI)
DATABASE_URL=postgresql+asyncpg://monteland:CHANGE_ME_strong_db_password@postgres:5432/monteland

# Sync URL (Alembic migrations)
SYNC_DATABASE_URL=postgresql://monteland:CHANGE_ME_strong_db_password@postgres:5432/monteland

# ── Redis ─────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0

# ── CORS ─────────────────────────────────────────────
# Production: set to your actual domain
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ── Cookies (set to true on production HTTPS) ─────────
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Frontend ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Cloudflare R2 (file storage) ─────────────────────
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@monteland.me
EMAIL_FROM_NAME=MonteLand

# ── AI / Anthropic ────────────────────────────────────
ANTHROPIC_API_KEY=
AI_MODEL_FAST=claude-haiku-4-5-20251001
AI_MODEL_QUALITY=claude-sonnet-4-6

# ── Telegram Bot ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Error tracking (Sentry) ──────────────────────────
# Free at sentry.io — create project "monteland-fastapi", copy DSN here
SENTRY_DSN=

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
# Production: /var/log/monteland/app.log (mounted Docker volume)
# Dev: leave empty (stdout only)
LOG_FILE=

# ── pgAdmin (dev only) ────────────────────────────────
PGADMIN_EMAIL=admin@monteland.local
PGADMIN_PASSWORD=admin